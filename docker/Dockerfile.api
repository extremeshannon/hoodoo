FROM python:3.12-slim-bookworm

WORKDIR /app

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV REPO_ROOT=/app

COPY backend/requirements.txt /tmp/requirements.txt
RUN pip install --no-cache-dir -r /tmp/requirements.txt

COPY backend/app /app/app
COPY backend/alembic.ini /app/alembic.ini
COPY backend/alembic /app/alembic
COPY data /app/data
COPY index.html configurator.html cart.html login.html register.html forgot-password.html account.html order.html viewer.html admin.html main.js styles.css configurator.css configurator.js cart.js favicon.svg /app/
COPY js /app/js
COPY 3d /app/3d
COPY assets /app/assets

EXPOSE 8000

CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]
