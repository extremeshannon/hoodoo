# Copy to `.env` for docker compose. On first API start, bootstrap creates one staff user if that email is new.
# Sign in at /login with BOOTSTRAP_STAFF_EMAIL or BOOTSTRAP_STAFF_USERNAME + BOOTSTRAP_STAFF_PASSWORD.
# Never commit `.env`.
BOOTSTRAP_STAFF_EMAIL=admin@hoodooak.com
BOOTSTRAP_STAFF_USERNAME=admin
BOOTSTRAP_STAFF_PASSWORD=change-this-password
BOOTSTRAP_STAFF_ROLE=admin
